%% --- Section heading with accent line ---
\newcommand{\cvsection}[2][]{%
  \vspace{10pt}%
  \noindent%
  {\Large\bfseries\color{accent}\raisebox{0.5pt}{#1}\ifthenelse{\equal{#1}{}}{}{\enspace}#2}%
  \hfill\null%
  \par\nopagebreak\vspace{-7pt}%
  {\color{accent}\rule{\textwidth}{0.6pt}}%
  \par\nopagebreak\vspace{3pt}%
}

%% --- Subsection heading (e.g. product names) ---
\newcommand{\cvsubsection}[1]{%
  \vspace{6pt}%
  {\normalsize\bfseries\color{accent}#1}\par\nopagebreak%
  \vspace{1pt}%
}

%% --- Technology tag pills ---
\newcommand{\techtag}[1]{%
  \tikz[baseline=(tag.base)]{%
    \node[fill=tagbg, rounded corners=2.5pt, inner xsep=4pt, inner ysep=1.5pt,
          font=\scriptsize\sffamily\color{dark}] (tag) {#1};%
  }\,%
}

%% --- Skill level indicator (filled/empty circles) ---
\newcommand{\skilllevel}[1]{%
  \ifthenelse{\equal{#1}{expert}}{%
    {\color{accent}\faCircle\;\faCircle\;\faCircle}%
  }{%
    \ifthenelse{\equal{#1}{proficient}}{%
      {\color{accent}\faCircle\;\faCircle}\;{\color{rulecol}\faCircle}%
    }{%
      {\color{accent}\faCircle}\;{\color{rulecol}\faCircle\;\faCircle}%
    }%
  }%
}

%% --- Quote block for recommendations ---
\newcommand{\quoteblock}[3]{%
  % #1 = quote text, #2 = author, #3 = role
  \vspace{3pt}%
  \noindent%
  \begin{tikzpicture}
    \node[fill=quotebg, rounded corners=3pt, inner sep=8pt, text width=\textwidth-20pt,
          draw=rulecol, line width=0.3pt] (q) {%
      {\small\itshape\color{mid}\cvquote{#1}}\\[4pt]
      {\footnotesize\bfseries\color{dark}--- #2,} {\footnotesize\color{mid}#3}%
    };
  \end{tikzpicture}%
  \vspace{2pt}%
}

%% --- Timeline dot for work entries ---
\newcommand{\timelinedot}{%
  \tikz[baseline=-0.6ex]{\fill[timelinedot] (0,0) circle (2.5pt);}%
}

